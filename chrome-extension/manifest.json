{
  "manifest_version": 3,
  "name": "FSD Browser Relay",
  "version": "1.0.0",
  "description": "Bridge between Chrome and local FSD agent loop. Direct use of authenticated browser sessions.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
